# Conan profile used by the Makefile (copy to ~/.conan2/profiles/).
# Adjust CC/CXX below to your GCC >= 15 installation.
[settings]
arch=x86_64
build_type=Release
compiler=gcc
compiler.cppstd=23
compiler.libcxx=libstdc++11
compiler.version=14
os=Linux

[buildenv]
CC=/usr/local/gcc-14.1.0/bin/gcc-14.1.0
CXX=/usr/local/gcc-14.1.0/bin/g++-14.1.0
# CPATH from ~/.bashrc (system solver installs) shadows conan -isystem includes
CPATH=!

[tool_requires]
cmake/3.30.5

[conf]
# prevent the system papilo (installed in /usr/local by scipoptsuite) from
# being picked up by find_package in the soplex and scip builds
soplex/*:tools.cmake.cmaketoolchain:extra_variables={"PAPILO": "OFF"}
scip/*:tools.cmake.cmaketoolchain:extra_variables={"PAPILO": "OFF"}