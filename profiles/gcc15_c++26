# Conan profile used by the Makefile (copy to ~/.conan2/profiles/).
# Adjust CC/CXX below to your GCC >= 15 installation.
[settings]
arch=x86_64
build_type=Release
compiler=gcc
compiler.cppstd=26
compiler.libcxx=libstdc++11
compiler.version=15
os=Linux

[buildenv]
CC=/opt/gcc-15/bin/gcc
CXX=/opt/gcc-15/bin/g++
# CPATH entries (e.g. system solver installs) shadow conan -isystem includes
CPATH=!

[tool_requires]
cmake/3.30.5

[conf]
# gcc15 defaults to C23 which rejects gmp's K&R-style configure tests
gmp/*:tools.build:cflags=["-std=gnu17"]
# prevent a system papilo (e.g. installed in /usr/local by scipoptsuite) from
# being picked up by find_package in the soplex and scip builds
soplex/*:tools.cmake.cmaketoolchain:extra_variables={"PAPILO": "OFF"}
scip/*:tools.cmake.cmaketoolchain:extra_variables={"PAPILO": "OFF"}
